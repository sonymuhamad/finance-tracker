# ─────────────────────────────────────────────────────────────
# Copy to `.env` and fill in values:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Database — local Postgres. Create the DB first:  createdb finance_tracker
DATABASE_URL="postgres://<user>:<password>@127.0.0.1:5432/finance_tracker?sslmode=disable"

# Auth.js — generate with: bunx auth secret
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Google OAuth credentials (from Google Cloud Console)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# App environment: development | staging | production
NEXT_PUBLIC_APP_ENV="development"

# Email-only dev-login (bypasses OAuth). MUST be "false" in production.
DEV_LOGIN_ENABLED="true"
