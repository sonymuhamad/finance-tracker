# ─────────────────────────────────────────────────────────────
# Copy to `.env` and fill in values:  cp .env.example .env
# See docs/pre-launch-hardening.md before deploying to production.
# ─────────────────────────────────────────────────────────────

# Database — local Postgres. Create the DB first:  createdb finance_tracker
# PRODUCTION: use sslmode=require (or verify-full) — never sslmode=disable.
DATABASE_URL="postgres://<user>:<password>@127.0.0.1:5432/finance_tracker?sslmode=disable"

# Auth.js — generate with: bunx auth secret
# PRODUCTION: a unique, high-entropy secret in the host's secret store; never
# reuse the dev/staging value. The app won't boot without it.
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Google OAuth credentials (from Google Cloud Console)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# App environment: development | staging | production
NEXT_PUBLIC_APP_ENV="development"

# Email-only dev-login (bypasses OAuth — a full auth bypass). MUST be unset/false
# in production. Belt-and-suspenders: the code also hard-disables it whenever
# NODE_ENV === "production", so a stray "true" here can't enable it in a prod build.
DEV_LOGIN_ENABLED="true"
